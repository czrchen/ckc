---

<Layout path="/products" title="Products — Cheong Kim Chuan (C.K.C.) Penang Nutmeg House">
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow" data-reveal>Our products</span>
      <h1 class="page-title" data-split>Penang's nutmeg pantry, since 1937</h1>
      <p class="page-lead" data-reveal>
        From preserved nutmeg and Tau Sar Pneah to belacan, rojak sauce and medicated oils —
        explore the full range of traditional flavours we still make the heritage way.
      </p>
    </div>
  </section>

  <section class="filter-sec">
    <div class="container">
      <div class="filter-bar" data-reveal role="tablist" aria-label="Filter products">
        {filters.map((f, i) => (
          <button class={`filter-btn${i === 0 ? " active" : ""}`} data-filter={f.key}>{f.label}</button>
        ))}
      </div>

      <div class="prod-grid" id="prod-grid" data-reveal-group>
        {products.map((p) => (
          <article class="pcard" data-cat={p.cat}>
            <div class="pcard-media">
              <img src={p.img} alt={p.name} loading="lazy" width="320" height="352" />
              <span class="pcard-tag">{labels[p.cat]}</span>
            </div>
            <div class="pcard-body">
              <h3>{p.name}</h3>
            </div>
          </article>
        ))}
      </div>
      <p class="no-results" id="no-results" hidden>No products in this category.</p>
    </div>
  </section>
</Layout>

<style>
  .page-hero { padding: 64px 0 36px; }
  .page-title { font-size: clamp(2.4rem, 5.4vw, 3.8rem); margin: 18px 0 18px; letter-spacing: -0.04em; }
  .page-lead { font-size: 1.12rem; color: var(--ink-soft); max-width: 640px; line-height: 1.65; }

  .filter-sec { padding: 10px 0 0; }
  .filter-bar { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 38px; }
  .filter-btn {
    font-family: var(--font-body); font-weight: 600; font-size: .92rem; cursor: pointer;
    padding: 10px 18px; border-radius: 999px; border: 1px solid var(--line-strong);
    background: #fff; color: var(--ink-soft); transition: all .2s ease;
  }
  .filter-btn:hover { border-color: var(--gold); color: var(--ink); }
  .filter-btn.active { background: var(--navy); border-color: var(--navy); color: #fff; }

  .prod-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; }
  .pcard { display: block; }
  .pcard.is-hidden { display: none; }
  .pcard-media {
    position: relative; aspect-ratio: 1/1.05; overflow: hidden; border-radius: 22px; background: var(--cream);
    box-shadow: 0 0 0 rgba(74,47,23,0);
    transition: transform .4s cubic-bezier(.2,.8,.25,1), box-shadow .4s ease;
  }
  .pcard-media img { width: 100%; height: 100%; object-fit: cover; transition: transform .6s cubic-bezier(.2,.8,.25,1); }
  .pcard-tag {
    position: absolute; left: 12px; top: 12px; font-size: .68rem; font-weight: 700; letter-spacing: .04em;
    text-transform: uppercase; color: var(--navy); background: rgba(255,255,255,.9);
    padding: 5px 10px; border-radius: 999px; backdrop-filter: blur(4px);
  }
  .pcard:hover .pcard-media { transform: translateY(-10px); box-shadow: 0 24px 40px rgba(192,69,31,.18); }
  .pcard:hover .pcard-media img { transform: scale(1.07); }
  .pcard-body { padding: 16px 4px 0; }
  .pcard-body h3 { font-size: .98rem; letter-spacing: -0.01em; line-height: 1.35; transition: color .25s ease; }
  .pcard:hover .pcard-body h3 { color: var(--red); }
  .no-results { text-align: center; color: var(--ink-soft); padding: 40px 0; font-weight: 600; }

  .oem-box { display: flex; justify-content: space-between; align-items: center; gap: 36px; flex-wrap: wrap; }
  .oem-box h2 { color: #fff; font-size: clamp(1.8rem, 3.6vw, 2.5rem); margin-bottom: 12px; }
  .oem-box p { color: rgba(255,255,255,.82); max-width: 520px; }
  .oem-box .btn { flex-shrink: 0; }

  @media (max-width: 900px) { .prod-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) {
    .prod-grid { grid-template-columns: 1fr 1fr; gap: 14px; }
    .oem-box { padding: 40px 30px; }
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const cards = document.querySelectorAll<HTMLElement>(".pcard");
  const noResults = document.getElementById("no-results");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const key = btn.dataset.filter;
      buttons.forEach((b) => b.classList.toggle("active", b === btn));
      let shown = 0;
      cards.forEach((c) => {
        const match = key === "all" || c.dataset.cat === key;
        c.classList.toggle("is-hidden", !match);
        if (match) shown++;
      });
      if (noResults) noResults.hidden = shown !== 0;
      window.dispatchEvent(new Event("resize"));
    });
  });
</script>
