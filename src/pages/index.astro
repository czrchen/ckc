---
import Layout from "../layouts/Layout.astro";
import Wave from "../components/Wave.astro";
---

<Layout path="/">
  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg" data-hero-bg></div>
    <div class="hero-scrim"></div>
    <div class="container hero-inner" data-hero-stagger>
      <span class="eyebrow eyebrow-light">Penang Heritage · Est. 1937</span>
      <h1 data-split>The taste of Penang, since 1937.</h1>
      <div class="hero-actions">
        <a href="/products" class="btn btn-primary">Explore products
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a href="/about" class="btn btn-light">Our story</a>
      </div>
    </div>
    <div class="hero-curve" aria-hidden="true">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none"><path d="M0,120 L0,60 Q720,-20 1440,60 L1440,120 Z" fill="var(--paper)"/></svg>
    </div>
  </section>

  <!-- SHOWCASE -->
  <section class="showcase">
    <div class="container">
      <header class="sec-head row" data-reveal>
        <div><span class="eyebrow">Best sellers</span><h2 class="section-title" data-split>Customer favourites</h2></div>
        <a href="/products" class="btn btn-ghost">All products
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
      </header>
      <div class="show-grid" data-reveal-group>
        <a href="/products" class="show-card">
          <span class="show-rank">01</span>
          <div class="show-media"><img src="/images/products/100-GroupPreservedFruit.jpg" alt="100 Grouppreservedfruit" loading="lazy" /></div>
          <div class="show-info"><span class="prod-cat">Signature</span><h3>100 Grouppreservedfruit</h3></div>
        </a>
        <a href="/products" class="show-card">
          <span class="show-rank">02</span>
          <div class="show-media"><img src="/images/products/200-GroupBiscuits.jpg" alt="200 Groupbiscuits" loading="lazy" /></div>
          <div class="show-info"><span class="prod-cat">Popular</span><h3>200 Groupbiscuits</h3></div>
        </a>
        <a href="/products" class="show-card">
          <span class="show-rank">03</span>
          <div class="show-media"><img src="/images/products/300-GroupSauces.jpg" alt="300 Groupsauces" loading="lazy" /></div>
          <div class="show-info"><span class="prod-cat">Bestseller</span><h3>300 Groupsauces</h3></div>
        </a>
        <a href="/products" class="show-card">
          <span class="show-rank">04</span>
          <div class="show-media"><img src="/images/products/400-GroupBeverage.jpg" alt="400 Groupbeverage" loading="lazy" /></div>
          <div class="show-info"><span class="prod-cat">Favourite</span><h3>400 Groupbeverage</h3></div>
        </a>
      </div>
    </div>
  </section>

  <!-- PROMO -->
  <section class="promo ribbon">
    <Wave side="top" /><Wave side="bottom" />
    <div class="ribbon-inner">
      <div class="container promo-grid">
        <div class="promo-art" data-reveal><img src="/images/products/ointment-5.jpg" alt="Cheong Kim Chuan (C.K.C.)" data-parallax="20" /></div>
        <div class="promo-copy" data-reveal>
          <span class="eyebrow">Why Cheong Kim Chuan (C.K.C.)</span>
          <h2 data-split data-split-accent="1">Made to a higher standard.</h2>
          <p>Quality ingredients, careful manufacturing and dependable supply — that's what goes into every Cheong Kim Chuan (C.K.C.) product.</p>
          <a href="/products" class="btn btn-primary">Explore the range
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        </div>
      </div>
    </div>
  </section>

  <!-- TILES -->
  <section class="flavours">
    <div class="container">
      <header class="sec-head" data-reveal>
        <span class="eyebrow">The range</span><h2 class="section-title">Our products</h2>
        <p class="section-lead">A closer look at what we make — explore the full Cheong Kim Chuan (C.K.C.) range.</p>
      </header>
      <div class="flav-grid" data-reveal-group>
        <a href="/products" class="flav-tile">
          <div class="flav-media"><img src="/images/products/100-GroupPreservedFruit.jpg" alt="100 Grouppreservedfruit" loading="lazy" /></div><h3>100 Grouppreservedfruit</h3>
        </a>
        <a href="/products" class="flav-tile">
          <div class="flav-media"><img src="/images/products/200-GroupBiscuits.jpg" alt="200 Groupbiscuits" loading="lazy" /></div><h3>200 Groupbiscuits</h3>
        </a>
        <a href="/products" class="flav-tile">
          <div class="flav-media"><img src="/images/products/300-GroupSauces.jpg" alt="300 Groupsauces" loading="lazy" /></div><h3>300 Groupsauces</h3>
        </a>
        <a href="/products" class="flav-tile">
          <div class="flav-media"><img src="/images/products/400-GroupBeverage.jpg" alt="400 Groupbeverage" loading="lazy" /></div><h3>400 Groupbeverage</h3>
        </a>
        <a href="/products" class="flav-tile">
          <div class="flav-media"><img src="/images/products/500-GroupOintment-1.jpg" alt="500 Groupointment 1" loading="lazy" /></div><h3>500 Groupointment 1</h3>
        </a>
        <a href="/products" class="flav-tile">
          <div class="flav-media"><img src="/images/products/600-GroupOtherProducts.jpg" alt="600 Groupotherproducts" loading="lazy" /></div><h3>600 Groupotherproducts</h3>
        </a>
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="values ribbon ribbon-cream">
    <Wave side="top" /><Wave side="bottom" />
    <div class="ribbon-inner"><div class="container">
      <header class="sec-head center" data-reveal>
        <span class="eyebrow center">Why choose us</span><h2 class="section-title">Trusted since 1937</h2>
      </header>
      <div class="val-grid" data-reveal-group>
          <div class="val-item">
            <div class="val-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={`<path d="M12 2l8 4v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-4Z"/><path d="M9 12l2 2 4-4"/>`} /></div>
            <h3>Trusted Quality</h3><p>Consistent, carefully made products Cheong Kim Chuan (C.K.C.) stands behind — every batch.</p>
          </div>
          <div class="val-item">
            <div class="val-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={`<path d="M12 2l2.5 6.5L21 9l-5 4 1.8 7L12 16.5 6.2 20 8 13 3 9l6.5-.5L12 2Z"/>`} /></div>
            <h3>Halal Certified</h3><p>Halal-compliant production you and your customers can trust.</p>
          </div>
          <div class="val-item">
            <div class="val-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={`<path d="M12 21s-7-5.6-7-11a7 7 0 0 1 14 0c0 5.4-7 11-7 11Z"/><circle cx="12" cy="10" r="2.6"/>`} /></div>
            <h3>Made in Malaysia</h3><p>Proudly manufactured locally and supplied across the region.</p>
          </div>
          <div class="val-item">
            <div class="val-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={`<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>`} /></div>
            <h3>Since 1937</h3><p>A trusted name for over 89 years.</p>
          </div>
      </div>
    </div></div>
  </section>

  <!-- ABOUT -->
  <section class="about">
    <div class="container about-grid">
      <div class="about-media" data-reveal>
        <div class="about-frame"><img src="/images/products/sauces-9.jpg" alt="Cheong Kim Chuan (C.K.C.)" data-parallax="-22" /></div>
        <div class="about-stat" data-parallax="20"><span class="num"><span data-count="89">0</span>+</span><span class="lbl">years of<br>heritage</span></div>
      </div>
      <div class="about-copy" data-reveal>
        <span class="eyebrow">Our story</span>
        <h2 class="section-title">About Cheong Kim Chuan (C.K.C.)</h2>
        <p class="section-lead">Cheong Kim Chuan (C.K.C.) — Penang Nutmeg House Since 1937. We focus on consistent quality, dependable supply and products our customers come back for.</p>
        <ul class="about-list" data-scrub>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6"><path d="M20 6L9 17l-5-5"/></svg><div><strong>Consistent quality</strong><span>Carefully made, batch after batch.</span></div></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6"><path d="M20 6L9 17l-5-5"/></svg><div><strong>Halal &amp; OEM ready</strong><span>Trusted production with OEM partnerships available.</span></div></li>
          <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6"><path d="M20 6L9 17l-5-5"/></svg><div><strong>Made in Malaysia</strong><span>Crafted locally, supplied widely.</span></div></li>
        </ul>
        <a href="/about" class="btn btn-ghost">More about us
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="reviews ribbon" id="reviews">
    <Wave side="top" /><Wave side="bottom" />
    <div class="ribbon-inner"><div class="container">
      <header class="sec-head center" data-reveal><span class="eyebrow center">Loved by customers</span><h2 class="section-title">What people say</h2></header>
      <div class="rv-carousel" data-carousel>
        <div class="rv-track" data-rv-track>
            <figure class="rv-slide">
              <div class="rv-stars" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.6 6.6L21 9.3l-5 4.3 1.6 6.9L12 16.9 6.4 20.5 8 13.6 3 9.3l6.4-.7L12 2Z"/></svg><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.6 6.6L21 9.3l-5 4.3 1.6 6.9L12 16.9 6.4 20.5 8 13.6 3 9.3l6.4-.7L12 2Z"/></svg><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.6 6.6L21 9.3l-5 4.3 1.6 6.9L12 16.9 6.4 20.5 8 13.6 3 9.3l6.4-.7L12 2Z"/></svg><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.6 6.6L21 9.3l-5 4.3 1.6 6.9L12 16.9 6.4 20.5 8 13.6 3 9.3l6.4-.7L12 2Z"/></svg><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.6 6.6L21 9.3l-5 4.3 1.6 6.9L12 16.9 6.4 20.5 8 13.6 3 9.3l6.4-.7L12 2Z"/></svg></div>
              <blockquote>Genuinely impressed with Cheong Kim Chuan (C.K.C.) — the quality is consistent and exactly what we expected. Will reorder.</blockquote>
              <figcaption><strong>Nurul A.</strong><span>Kuala Lumpur</span></figcaption>
            </figure>
            <figure class="rv-slide">
              <div class="rv-stars" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.6 6.6L21 9.3l-5 4.3 1.6 6.9L12 16.9 6.4 20.5 8 13.6 3 9.3l6.4-.7L12 2Z"/></svg><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.6 6.6L21 9.3l-5 4.3 1.6 6.9L12 16.9 6.4 20.5 8 13.6 3 9.3l6.4-.7L12 2Z"/></svg><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.6 6.6L21 9.3l-5 4.3 1.6 6.9L12 16.9 6.4 20.5 8 13.6 3 9.3l6.4-.7L12 2Z"/></svg><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.6 6.6L21 9.3l-5 4.3 1.6 6.9L12 16.9 6.4 20.5 8 13.6 3 9.3l6.4-.7L12 2Z"/></svg><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.6 6.6L21 9.3l-5 4.3 1.6 6.9L12 16.9 6.4 20.5 8 13.6 3 9.3l6.4-.7L12 2Z"/></svg></div>
              <blockquote>We've worked with Cheong Kim Chuan (C.K.C.) for a while now. Reliable supply and our customers keep coming back.</blockquote>
              <figcaption><strong>Wei Jie T.</strong><span>Retail partner</span></figcaption>
            </figure>
            <figure class="rv-slide">
              <div class="rv-stars" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.6 6.6L21 9.3l-5 4.3 1.6 6.9L12 16.9 6.4 20.5 8 13.6 3 9.3l6.4-.7L12 2Z"/></svg><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.6 6.6L21 9.3l-5 4.3 1.6 6.9L12 16.9 6.4 20.5 8 13.6 3 9.3l6.4-.7L12 2Z"/></svg><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.6 6.6L21 9.3l-5 4.3 1.6 6.9L12 16.9 6.4 20.5 8 13.6 3 9.3l6.4-.7L12 2Z"/></svg><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.6 6.6L21 9.3l-5 4.3 1.6 6.9L12 16.9 6.4 20.5 8 13.6 3 9.3l6.4-.7L12 2Z"/></svg><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.6 6.6L21 9.3l-5 4.3 1.6 6.9L12 16.9 6.4 20.5 8 13.6 3 9.3l6.4-.7L12 2Z"/></svg></div>
              <blockquote>Great value and dependable quality. Easy to deal with and quick to respond. Recommended.</blockquote>
              <figcaption><strong>Suresh K.</strong><span>Penang</span></figcaption>
            </figure>
        </div>
        <div class="rv-dots" data-rv-dots><button class="active" data-rv-dot="0" aria-label="Review 1"></button><button class="" data-rv-dot="1" aria-label="Review 2"></button><button class="" data-rv-dot="2" aria-label="Review 3"></button></div>
      </div>
    </div></div>
  </section>
</Layout>

<style>
  /* ---------- HERO (full-bleed product scene) ---------- */
  .hero { position: relative; min-height: 100vh; display: flex; align-items: center; overflow: hidden; background: var(--red-deep); }
  .hero-bg { position: absolute; inset: 0; background: url(/images/hero/hero-bg.png?v=2) center center / cover no-repeat; transform: scale(1.06); will-change: transform; }
  .hero-scrim { position: absolute; inset: 0; background:
      linear-gradient(95deg, rgba(28,8,7,.92) 0%, rgba(28,8,7,.74) 26%, rgba(28,8,7,.34) 48%, rgba(28,8,7,0) 70%),
      linear-gradient(0deg, rgba(28,8,7,.4) 0%, rgba(28,8,7,0) 24%); }
  .hero-inner { position: relative; z-index: 2; padding-top: 132px; padding-bottom: 120px; }
  .hero-inner .eyebrow-light, .hero-inner .eyebrow-light::before { color: var(--gold); }
  .hero-inner .eyebrow-light::before { background: var(--gold); }
  .hero-inner h1 { color: #fff; font-size: clamp(3rem, 6.6vw, 5.4rem); margin: 20px 0 22px; letter-spacing: -0.045em; max-width: 13ch; text-shadow: 0 4px 40px rgba(0,0,0,.3); }
  .hero-inner h1 .split-word > span[style] { color: var(--gold) !important; }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; margin: 30px 0 0; }
  .hero-curve { position: absolute; left: 0; right: 0; bottom: -1px; z-index: 3; line-height: 0; pointer-events: none; }
  .hero-curve svg { width: 100%; height: clamp(56px, 7vw, 110px); display: block; }

  /* ---------- shared section header ---------- */
  .sec-head { margin-bottom: 48px; }
  .sec-head.row { display: flex; justify-content: space-between; align-items: flex-end; gap: 24px; flex-wrap: wrap; }
  .sec-head.center .section-lead { margin-left: auto; margin-right: auto; }

  /* ---------- BEST SELLERS SHOWCASE ---------- */
  .showcase { padding: 100px 0 0; }
  .show-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; }
  .show-card { display: block; position: relative; }
  .show-rank { font-family: var(--font-display); font-weight: 800; font-size: .9rem; color: var(--line-strong); }
  .show-media { aspect-ratio: 1/1; overflow: hidden; border-radius: 26px; background: var(--cream); margin-top: 8px; box-shadow: 0 0 0 rgba(36,26,23,0); transition: transform .4s cubic-bezier(.2,.8,.25,1), box-shadow .4s ease; }
  .show-media img { width: 100%; height: 100%; object-fit: contain; padding: 18px; transition: transform .6s cubic-bezier(.2,.8,.25,1); }
  .show-card:hover .show-media { transform: translateY(-12px); box-shadow: 0 26px 44px rgba(232,51,44,.18); }
  .show-card:hover .show-media img { transform: scale(1.08); }
  .show-info { padding: 16px 4px 0; }
  .prod-cat { font-size: .72rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: var(--red); }
  .show-info h3 { font-size: 1.1rem; margin-top: 6px; letter-spacing: -0.02em; }

  /* ---------- PROMO BANNER ---------- */
  .promo { background: var(--navy); }
  .promo .ribbon-inner { padding: 84px 0; }
  .promo-grid { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 56px; align-items: center; }
  .promo-art { border-radius: var(--r-lg); overflow: hidden; aspect-ratio: 5/4; background: rgba(255,255,255,.06); display: grid; place-items: center; }
  .promo-art img { width: 100%; height: 110%; object-fit: contain; padding: 24px; }
  .promo-copy h2 { color: #fff; font-size: clamp(2rem, 4.6vw, 3.2rem); letter-spacing: -0.035em; margin-bottom: 18px; }
  .promo-copy p { color: rgba(255,255,255,.78); font-size: 1.08rem; max-width: 460px; margin-bottom: 28px; line-height: 1.65; }

  /* ---------- FLAVOUR TILES ---------- */
  .flavours { padding: 100px 0 0; }
  .flav-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 34px; }
  .flav-tile { display: block; text-align: center; }
  .flav-media { aspect-ratio: 4/3; overflow: hidden; border-radius: 24px; background: var(--cream); box-shadow: 0 0 0 rgba(36,26,23,0); transition: transform .4s cubic-bezier(.2,.8,.25,1), box-shadow .4s ease; }
  .flav-media img { width: 100%; height: 100%; object-fit: contain; padding: 22px; transition: transform .6s cubic-bezier(.2,.8,.25,1); }
  .flav-tile:hover .flav-media { transform: translateY(-8px); box-shadow: var(--shadow-md); }
  .flav-tile:hover .flav-media img { transform: scale(1.06) rotate(-2deg); }
  .flav-tile h3 { font-size: 1.15rem; margin-top: 16px; letter-spacing: -0.02em; transition: color .25s ease; }
  .flav-tile:hover h3 { color: var(--red); }

  /* ---------- VALUE BADGES ---------- */
  .val-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; }
  .val-item { text-align: center; }
  .val-icon {
    width: 84px; height: 84px; margin: 0 auto 20px; border-radius: 50%;
    background: var(--white); display: grid; place-items: center;
    box-shadow: var(--shadow-sm); border: 1px solid var(--line);
    transition: transform .35s cubic-bezier(.2,.8,.25,1), box-shadow .35s ease;
  }
  .val-icon svg { width: 36px; height: 36px; color: var(--red); }
  .val-item:hover .val-icon { transform: translateY(-6px) scale(1.04); box-shadow: var(--shadow-md); }
  .val-item h3 { font-size: 1.15rem; margin-bottom: 8px; letter-spacing: -0.02em; }
  .val-item p { color: var(--ink-soft); font-size: .95rem; line-height: 1.55; max-width: 240px; margin: 0 auto; }

  /* ---------- ABOUT ---------- */
  .about { padding: 110px 0 0; }
  .about-grid { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 60px; align-items: center; }
  .about-media { position: relative; }
  .about-frame { border-radius: var(--r-lg); overflow: hidden; aspect-ratio: 14/15; box-shadow: var(--shadow-md); background: var(--cream); }
  .about-frame img { width: 100%; height: 114%; object-fit: contain; padding: 28px; }
  .about-stat { position: absolute; right: -22px; bottom: 32px; z-index: 2; background: var(--red); color: #fff; border-radius: 16px; padding: 18px 22px; box-shadow: 0 18px 40px rgba(218,33,40,.3); display: flex; align-items: center; gap: 12px; }
  .about-stat .num { font-family: var(--font-display); font-weight: 700; font-size: 2.4rem; line-height: 1; }
  .about-stat .lbl { font-size: .82rem; line-height: 1.25; opacity: .95; }
  .about-copy .section-title { font-size: clamp(1.8rem, 3.6vw, 2.7rem); }
  .about-list { margin: 28px 0; display: grid; gap: 16px; }
  .about-list li { display: flex; gap: 14px; align-items: flex-start; }
  .about-list svg { width: 22px; height: 22px; color: var(--red); flex-shrink: 0; margin-top: 2px; }
  .about-list strong { display: block; font-family: var(--font-display); font-size: 1.02rem; margin-bottom: 2px; }
  .about-list span { color: var(--ink-soft); font-size: .96rem; }

  /* ---------- TESTIMONIALS CAROUSEL ---------- */
  .rv-carousel { max-width: 760px; margin: 0 auto; overflow: hidden; }
  .rv-track { display: flex; will-change: transform; transition: transform .6s cubic-bezier(.5,0,.2,1); }
  .rv-slide { flex: 0 0 100%; text-align: center; padding: 0 20px; }
  .rv-stars { display: flex; justify-content: center; gap: 5px; margin-bottom: 22px; }
  .rv-stars svg { width: 22px; height: 22px; color: var(--gold); }
  .rv-slide blockquote { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.25rem, 2.6vw, 1.7rem); line-height: 1.4; color: #fff; letter-spacing: -0.02em; }
  .rv-slide figcaption { margin-top: 26px; }
  .rv-slide figcaption strong { display: block; color: #fff; font-family: var(--font-display); font-size: 1rem; }
  .rv-slide figcaption span { color: rgba(255,255,255,.6); font-size: .9rem; }
  .rv-dots { display: flex; justify-content: center; gap: 10px; margin-top: 38px; }
  .rv-dots button { width: 9px; height: 9px; border-radius: 50%; border: none; cursor: pointer; padding: 0; background: rgba(255,255,255,.28); transition: background .25s ease, width .25s ease; }
  .rv-dots button.active { background: var(--gold); width: 26px; border-radius: 999px; }

  /* ---------- CERTIFICATIONS BELT ---------- */

  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 960px) {
    .hero-grid { grid-template-columns: 1fr; gap: 70px; }
    .hero-art { max-width: 520px; }
    .promo-grid { grid-template-columns: 1fr; gap: 40px; }
    .promo-art { max-width: 460px; }
    .about-grid { grid-template-columns: 1fr; gap: 40px; }
    .about-media { max-width: 460px; }
    .show-grid { grid-template-columns: 1fr 1fr; gap: 26px; }
    .flav-grid { grid-template-columns: 1fr 1fr; }
    .val-grid { grid-template-columns: 1fr 1fr; gap: 40px 24px; }
  }
  @media (max-width: 540px) {
    .show-grid { grid-template-columns: 1fr 1fr; gap: 16px; }
    .flav-grid { grid-template-columns: 1fr 1fr; gap: 18px; }
