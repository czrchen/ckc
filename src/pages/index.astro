---
import Layout from "../layouts/Layout.astro";
import Wave from "../components/Wave.astro";

const featured = [
  { img: "/images/products/biscuits-1.jpg", name: "Tau Sar Pneah (Original)", cat: "Biscuits" },
  { img: "/images/products/preserved-2.jpg", name: "Preserved Nutmeg Sweetened", cat: "Preserved Fruits" },
  { img: "/images/products/ointment-2.jpg", name: "Nutmeg Medicated Oil", cat: "Oils & Ointments" },
  { img: "/images/products/sauces-2.jpg", name: "Penang Rojak Sauce", cat: "Sauces & Paste" },
  { img: "/images/products/biscuits-2.jpg", name: "Tau Sar Pneah (Pandan)", cat: "Biscuits" },
  { img: "/images/products/preserved-1.jpg", name: "Preserved Nutmeg Liquorice", cat: "Preserved Fruits" },
];

const certs = [
  { img: "/images/certs/halal.png", name: "Halal" },
  { img: "/images/certs/haccp.png", name: "HACCP" },
  { img: "/images/certs/gmp.png", name: "GMP" },
  { img: "/images/certs/mesti.png", name: "MeSTI" },
];

const heritage = [
  { k: "Made since 1937", v: "From a single shop on the steps to Kek Lok Si Temple, Ayer Itam." },
  { k: "The golden bell", v: "A trademark recognised across Malaysia, Singapore and Hong Kong." },
  { k: "Traditional recipes", v: "Nutmeg, belacan and Tau Sar Pneah made the time-honoured way." },
];
---

<Layout path="/">
  <!-- ============ HERO ============ -->
  <section class="hero" style="background-image:url(/images/hero/hero-bg.png)">
    <div class="container hero-inner" data-hero-stagger>
      <span class="eyebrow eyebrow-light">Penang Heritage · Est. 1937</span>
      <h1 data-split>The taste of Penang, since 1937.</h1>
      <div class="hero-actions">
          <a href="/products" class="btn btn-primary">Explore products
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a href="/about" class="btn btn-light">Our story</a>
      </div>
    </div>
    <div class="hero-curve"><svg viewBox="0 0 1440 110" preserveAspectRatio="none"><path d="M0,46 C320,116 1040,4 1440,64 L1440,110 L0,110 Z" fill="var(--paper)"/></svg></div>
  </section>

  <!-- ============ TICKER ============ -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker-track">
      <span>Preserved Nutmeg</span><i></i><span>Tau Sar Pneah</span><i></i><span>Belacan</span><i></i>
      <span>Rojak Sauce</span><i></i><span>Asam Laksa Paste</span><i></i><span>Medicated Oils</span><i></i>
      <span>Preserved Nutmeg</span><i></i><span>Tau Sar Pneah</span><i></i><span>Belacan</span><i></i>
      <span>Rojak Sauce</span><i></i><span>Asam Laksa Paste</span><i></i><span>Medicated Oils</span><i></i>
    </div>
  </div>

  <!-- ============ COLLECTIONS ============ -->
  <section class="brands">
    <div class="container">
      <header class="sec-head" data-reveal>
        <div>
          <span class="eyebrow">Signature collections</span>
          <h2 class="section-title">Two icons, one heritage</h2>
        </div>
        <p class="section-lead">From the biscuit Penang is famous for to the nutmeg remedies passed down for generations.</p>
      </header>

      <div class="brand-grid" data-reveal-group>
        <article class="brand-card">
          <div class="brand-media"><img src="/images/products/200-GroupBiscuits.jpg" alt="Tau Sar Pneah" loading="lazy" /></div>
          <div class="brand-body">
            <span class="brand-tag tag-navy">Tambun Biscuits</span>
            <h3>The original Tau Sar Pneah</h3>
            <p>Flaky pastry and smooth green-bean filling — in original, pandan, coffee and nutmeg, baked fresh the way Penang loves it.</p>
            <a href="/products" class="textlink">View biscuits →</a>
          </div>
        </article>
        <article class="brand-card">
          <div class="brand-media"><img src="/images/products/500-GroupOintment-1.jpg" alt="Nutmeg oils and balms" loading="lazy" /></div>
          <div class="brand-body">
            <span class="brand-tag tag-red">Nutmeg Remedies</span>
            <h3>Medicated oils &amp; balms</h3>
            <p>Premium nutmeg mace oil, medicated oil and balm — traditional comfort, trusted by families for generations.</p>
            <a href="/products" class="textlink">View remedies →</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ FEATURED ============ -->
  <section class="featured">
    <div class="container">
      <header class="sec-head row" data-reveal>
        <div>
          <span class="eyebrow">Best sellers</span>
          <h2 class="section-title">Penang favourites</h2>
        </div>
        <a href="/products" class="btn btn-ghost">All products
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </header>

    </div>

    <div class="pin-wrap" data-pin-wrap>
      <div class="pin-track" data-pin-track>
        {featured.map((p, i) => (
          <a href="/products" class="pin-card">
            <span class="pin-index">{String(i + 1).padStart(2, "0")}</span>
            <div class="pin-media"><img src={p.img} alt={p.name} loading="lazy" /></div>
            <div class="pin-info">
              <span class="prod-cat">{p.cat}</span>
              <h3>{p.name}</h3>
            </div>
          </a>
        ))}
        <a href="/products" class="pin-card pin-card-cta">
          <span>See all<br>products</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ HERITAGE ============ -->
  <section class="quality">
    <div class="container quality-grid">
      <div class="quality-media" data-reveal>
        <div class="quality-frame">
          <img src="/images/products/100-GroupPreservedFruit.jpg" alt="Cheong Kim Chuan preserved nutmeg" width="560" height="600" loading="lazy" data-parallax="-26" />
        </div>
        <div class="quality-stat" data-parallax="22">
          <span class="num"><span data-count="88">0</span>+</span>
          <span class="lbl">years of Penang<br>nutmeg heritage</span>
        </div>
      </div>
      <div class="quality-copy" data-reveal>
        <span class="eyebrow">Why Cheong Kim Chuan</span>
        <h2 class="section-title">A trusted name, built one batch at a time</h2>
        <p class="section-lead">Since 1937 the golden bell has stood for quality and the satisfaction of every customer — the same care, recipe after recipe, generation after generation.</p>
        <ul class="quality-list" data-scrub>
          {heritage.map((q) => (
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6"><path d="M20 6L9 17l-5-5"/></svg>
              <div><strong>{q.k}</strong><span>{q.v}</span></div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ============ CERTIFICATIONS ============ -->
  <section class="certs ribbon ribbon-cream">
    <Wave side="top" />
    <Wave side="bottom" />
    <div class="ribbon-inner">
      <div class="container">
        <span class="eyebrow center certs-eyebrow">Certified &amp; trusted</span>
      </div>
      <div class="cert-belt">
        <div class="cert-belt-track">
          {[...certs, ...certs, ...certs, ...certs].map((c) => (
            <div class="cert-plate"><img src={c.img} alt={c.name} loading="lazy" /></div>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .accent { color: var(--red); }
  .textlink { font-weight: 600; color: var(--red); font-size: .95rem; }
  .textlink:hover { color: var(--red-deep); }

  /* ---------- HERO ---------- */
  .hero { padding: 72px 0 90px; }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 56px;
    align-items: center;
  }
  .hero-copy h1 {
    font-size: clamp(2.9rem, 6vw, 4.6rem);
    margin: 22px 0 22px;
    letter-spacing: -0.04em;
  }
  .hero-lead { font-size: 1.15rem; color: var(--ink-soft); max-width: 510px; line-height: 1.65; }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; margin: 32px 0 26px; }
  .hero-trust { font-size: .95rem; color: var(--ink-soft); }
  .hero-trust strong { color: var(--ink); font-weight: 700; }

  .hero-art { position: relative; }
  .hero-img-main {
    border-radius: var(--r-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    aspect-ratio: 6 / 5;
  }
  .hero-img-main img { width: 100%; height: 100%; object-fit: cover; }
  .hero-float {
    position: absolute; left: -28px; bottom: -28px;
    width: 230px; background: #fff;
    border-radius: 16px; padding: 10px; box-shadow: var(--shadow-md);
  }
  .hero-float img { width: 100%; border-radius: 9px; aspect-ratio: 7/5; object-fit: cover; }
  .hero-float figcaption { font-size: .76rem; font-weight: 600; color: var(--ink-soft); padding: 8px 4px 4px; }
  .hero-badge {
    position: absolute; top: -22px; right: -18px;
    display: flex; align-items: center; gap: 10px;
    background: var(--navy); color: #fff;
    padding: 12px 16px; border-radius: 14px; box-shadow: var(--shadow-md);
  }
  .hero-badge span { font-family: var(--font-display); font-size: .72rem; line-height: 1.1; letter-spacing: .04em; }
  .hero-badge strong { font-size: 1.05rem; color: var(--gold); }

  /* ---------- TICKER ---------- */
  .ticker { background: var(--navy); overflow: hidden; padding: 15px 0; }
  .ticker-track {
    display: flex; align-items: center; gap: 28px; white-space: nowrap; width: max-content;
    animation: scroll 30s linear infinite;
  }
  .ticker-track span {
    font-family: var(--font-display); font-weight: 600; font-size: .92rem;
    text-transform: uppercase; letter-spacing: .14em; color: rgba(255,255,255,.92);
  }
  .ticker-track i { width: 6px; height: 6px; border-radius: 50%; background: var(--gold); display: inline-block; }
  @keyframes scroll { to { transform: translateX(-50%); } }

  /* ---------- shared section header ---------- */
  .brands, .featured { padding: 100px 0 0; }
  .sec-head { margin-bottom: 48px; }
  .sec-head.row { display: flex; justify-content: space-between; align-items: flex-end; gap: 24px; flex-wrap: wrap; }
  .brands .sec-head { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; align-items: end; }
  .brands .sec-head .section-lead { margin-top: 0; }

  /* ---------- COLLECTIONS ---------- */
  .brand-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
  .brand-card { display: block; }
  .brand-media {
    overflow: hidden; border-radius: 28px; box-shadow: 0 0 0 rgba(74,47,23,0);
    transition: transform .4s cubic-bezier(.2,.8,.25,1), box-shadow .4s ease;
  }
  .brand-media img { width: 100%; aspect-ratio: 16/10; object-fit: cover; transition: transform .6s cubic-bezier(.2,.8,.25,1); }
  .brand-card:hover .brand-media { transform: translateY(-8px); box-shadow: var(--shadow-md); }
  .brand-card:hover .brand-media img { transform: scale(1.05); }
  .brand-body { padding: 24px 6px 0; }
  .brand-tag {
    display: inline-block; font-weight: 600; font-size: .74rem;
    letter-spacing: .1em; text-transform: uppercase; margin-bottom: 12px;
  }
  .tag-navy { color: var(--navy); }
  .tag-red { color: var(--red); }
  .brand-body h3 { font-size: 1.6rem; margin-bottom: 10px; letter-spacing: -0.03em; }
  .brand-body p { color: var(--ink-soft); font-size: 1rem; margin-bottom: 16px; max-width: 440px; }

  /* ---------- FEATURED ---------- */
  .prod-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 34px; }
  .prod-card { display: block; }
  .prod-media {
    aspect-ratio: 1/1; overflow: hidden; border-radius: 26px;
    background: var(--cream); box-shadow: 0 0 0 rgba(74,47,23,0);
    transition: transform .4s cubic-bezier(.2,.8,.25,1), box-shadow .4s ease;
  }
  .prod-media img { width: 100%; height: 100%; object-fit: cover; transition: transform .6s cubic-bezier(.2,.8,.25,1); }
  .prod-card:hover .prod-media { transform: translateY(-12px); box-shadow: 0 26px 44px rgba(192,69,31,.16); }
  .prod-card:hover .prod-media img { transform: scale(1.08); }
  .prod-info { padding: 18px 6px 0; }
  .prod-cat { font-size: .72rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: var(--red); }
  .prod-info h3 {
    font-size: 1.08rem; margin-top: 6px; letter-spacing: -0.02em;
    transition: color .25s ease; display: inline-flex; align-items: center; gap: 6px;
  }
  .prod-info h3::after {
    content: "→"; font-size: .95rem; opacity: 0; transform: translateX(-6px);
    transition: opacity .25s ease, transform .25s ease; color: var(--red);
  }
  .prod-card:hover .prod-info h3 { color: var(--red); }
  .prod-card:hover .prod-info h3::after { opacity: 1; transform: translateX(0); }

  /* ---------- HERITAGE ---------- */
  .quality { padding: 110px 0 0; }
  .quality-grid { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: 60px; align-items: center; }
  .quality-media { position: relative; }
  .quality-frame { border-radius: var(--r-lg); overflow: hidden; aspect-ratio: 14/15; box-shadow: var(--shadow-md); }
  .quality-frame img { width: 100%; height: 114%; object-fit: cover; object-position: center; }
  .quality-stat {
    position: absolute; right: -22px; bottom: 32px; z-index: 2;
    background: var(--red); color: #fff; border-radius: 16px;
    padding: 18px 22px; box-shadow: 0 18px 40px rgba(192,69,31,.3);
    display: flex; align-items: center; gap: 12px;
  }
  .quality-stat .num { font-family: var(--font-display); font-weight: 700; font-size: 2.4rem; line-height: 1; }
  .quality-stat .lbl { font-size: .82rem; line-height: 1.25; opacity: .95; }
  .quality-copy .section-title { font-size: clamp(1.8rem, 3.6vw, 2.7rem); }
  .quality-list { margin-top: 28px; display: grid; gap: 16px; }
  .quality-list li { display: flex; gap: 14px; align-items: flex-start; }
  .quality-list svg { width: 22px; height: 22px; color: var(--red); flex-shrink: 0; margin-top: 2px; }
  .quality-list strong { display: block; font-family: var(--font-display); font-size: 1.02rem; margin-bottom: 2px; }
  .quality-list span { color: var(--ink-soft); font-size: .96rem; }

  /* ---------- CERTIFICATIONS (conveyor belt) ---------- */
  .certs-eyebrow { display: flex; justify-content: center; margin-bottom: 40px; }
  .cert-belt {
    overflow: hidden;
    padding: 26px 0;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 9%, #000 91%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 9%, #000 91%, transparent);
  }
  .cert-belt-track {
    display: flex; gap: 26px; width: max-content;
    animation: beltScroll 30s linear infinite;
  }
  .cert-belt:hover .cert-belt-track { animation-play-state: paused; }
  .cert-plate {
    flex: 0 0 auto; width: 172px; height: 124px;
    background: #fff; border-radius: 20px; box-shadow: var(--shadow-sm);
    display: grid; place-items: center; padding: 24px;
    transition: transform .25s ease, box-shadow .25s ease;
  }
  .cert-plate:hover { transform: translateY(-7px); box-shadow: 0 14px 28px rgba(74,47,23,.14); }
  .cert-plate img { max-height: 70px; max-width: 100%; width: auto; object-fit: contain; }
  @keyframes beltScroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) {
    .cert-belt-track { animation: none; justify-content: center; }
  }

  /* ---------- CTA ---------- */
  .cta-box {
    display: flex; justify-content: space-between; align-items: center; gap: 36px; flex-wrap: wrap;
  }
  .cta-box h2 { color: #fff; font-size: clamp(1.8rem, 3.6vw, 2.7rem); margin-bottom: 12px; }
  .cta-box p { color: rgba(255,255,255,.8); max-width: 460px; }
  .cta-box .btn { flex-shrink: 0; }

  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 960px) {
    .hero-grid { grid-template-columns: 1fr; gap: 70px; }
    .hero-art { max-width: 520px; }
    .quality-grid { grid-template-columns: 1fr; gap: 40px; }
    .quality-media { max-width: 460px; }
    .prod-grid { grid-template-columns: 1fr 1fr; }
    .brand-grid { grid-template-columns: 1fr; }
    .brands .sec-head { grid-template-columns: 1fr; gap: 14px; }
  }
  @media (max-width: 560px) {
    .brand-card { grid-template-columns: 1fr; }
    .brand-media img { min-height: 200px; }
    .prod-grid { grid-template-columns: 1fr 1fr; gap: 14px; }
  }
  /* ---------- FEATURED — pinned horizontal strip ---------- */
  .pin-wrap { height: min(72vh, 560px); display: flex; align-items: stretch; overflow: hidden; }
  .pin-track { display: flex; align-items: stretch; gap: 30px; padding: 0 max(28px, calc((100vw - var(--maxw)) / 2 + 28px)); will-change: transform; }
  .pin-card {
    flex: 0 0 auto; width: 330px; position: relative;
    display: flex; flex-direction: column;
    background: var(--white, #fff); border: 1px solid var(--line); border-radius: var(--r-lg);
    box-shadow: var(--shadow-sm); padding: 26px 28px 24px; overflow: hidden;
    transition: box-shadow .4s ease, border-color .4s ease;
  }
  .pin-card:hover { box-shadow: var(--shadow-md); border-color: var(--line-strong); }
  .pin-index { font-family: var(--font-display); font-weight: 800; font-size: 1rem; color: var(--line-strong); }
  .pin-media { flex: 1; min-height: 0; background: var(--cream); border-radius: 18px; margin: 12px 0 18px; overflow: hidden; }
  .pin-media img { width: 100%; height: 100%; object-fit: contain; padding: 22px; transition: transform .6s cubic-bezier(.2,.8,.25,1); }
  .pin-card:hover .pin-media img { transform: scale(1.07); }
  .pin-info .prod-cat { font-size: .72rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase; color: var(--red); }
  .pin-info h3 { font-size: 1.3rem; margin-top: 6px; letter-spacing: -0.02em; }
  .pin-card-cta {
    width: 250px; background: var(--navy); color: #fff; display: flex; flex-direction: column;
    justify-content: center; gap: 16px;
  }
  .pin-card-cta span { font-family: var(--font-display); font-weight: 700; font-size: 1.6rem; line-height: 1.1; }
  .pin-card-cta svg { width: 26px; height: 26px; color: var(--gold); }
  .pin-card-cta:hover { background: var(--navy-2); }
  @media (max-width: 760px) {
    .pin-wrap { height: auto; overflow-x: auto; -webkit-overflow-scrolling: touch; padding: 6px 0 20px; scroll-snap-type: x mandatory; }
    .pin-track { padding: 0 20px; }
    .pin-card { width: 78vw; max-width: 320px; scroll-snap-align: center; }
  }

  /* === wisechip-hero (injected) === */
  .hero { position: relative; padding: 0; background-size: cover; background-position: center; overflow: hidden; }
  .hero::after { content: ""; position: absolute; inset: 0; z-index: 1; background: linear-gradient(90deg, rgba(0,0,0,.52), rgba(0,0,0,.18) 55%, transparent); }
  .hero-inner { position: relative; z-index: 2; padding: 150px 0 200px; max-width: 760px; }
  .hero-inner .eyebrow, .hero-inner .eyebrow::before { color: var(--gold); }
  .hero-inner .eyebrow::before { background: var(--gold); }
  .hero-inner h1 { color: #fff; font-size: clamp(2.6rem, 6vw, 5rem); margin: 18px 0 24px; letter-spacing: -0.04em; max-width: 14ch; text-shadow: 0 4px 40px rgba(0,0,0,.35); }
  .hero-inner h1 .split-word > span[style] { color: var(--gold) !important; }
  .hero-inner .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; margin: 0; }
  .btn-light { background: #fff; color: var(--ink); }
  .btn-light::before { background: var(--gold); }
  .btn-light:hover { color: var(--ink); }
  .hero-curve { position: absolute; left: 0; right: 0; bottom: -1px; z-index: 3; line-height: 0; pointer-events: none; }
  .hero-curve svg { width: 100%; height: clamp(56px, 7vw, 110px); display: block; }
  @media (max-width: 700px) { .hero-inner { padding: 120px 0 150px; } }

</style>
