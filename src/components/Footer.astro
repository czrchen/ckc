---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="brand">
        <img class="brand-mark" src="/images/logo.png" alt="Cheong Kim Chuan — Since 1937" width="60" height="60" />
        <span class="brand-text">Cheong Kim Chuan</span>
      </a>
      <p>Penang's house of nutmeg since 1937 — preserved fruits, Tau Sar Pneah, belacan, sauces and traditional medicated oils under the golden bell.</p>
      <div class="socials">
        <a href="#" aria-label="Facebook">Facebook</a>
        <a href="#" aria-label="Instagram">Instagram</a>
        <a href="#" aria-label="Shopee">Shopee</a>
      </div>
    </div>

    <div class="footer-col">
      <h4>Explore</h4>
      <a href="/">Home</a>
      <a href="/about">About Us</a>
      <a href="/products">Products</a>
      <a href="/contact">Contact</a>
    </div>

    <div class="footer-col">
      <h4>Our Range</h4>
      <a href="/products">Preserved Fruits</a>
      <a href="/products">Tau Sar Pneah</a>
      <a href="/products">Sauces &amp; Belacan</a>
      <a href="/products">Oils &amp; Ointments</a>
    </div>

    <div class="footer-col">
      <h4>Get in touch</h4>
      <p class="muted">Plot 63, Lintang Bayan Lepas 1, Bayan Lepas Industrial Park IV, 11900 Bayan Lepas, Penang, Malaysia</p>
      <a href="tel:+6046425577">+604-642 5577</a>
      <a href="mailto:mfg@ckc.com.my">mfg@ckc.com.my</a>
    </div>
  </div>

  <div class="container footer-bottom">
    <span>© {year} C.K.C. Food Industries Sdn Bhd · Since 1937</span>
    <span>Bayan Lepas, Penang, Malaysia</span>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    background: var(--navy);
    color: #E4D6C2;
    margin-top: 110px;
    padding: 70px 0 30px;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.7fr 1fr 1fr 1.4fr;
    gap: 40px;
  }
  .brand { display: flex; align-items: center; gap: 13px; margin-bottom: 18px; }
  .brand-mark { width: 56px; height: 56px; object-fit: contain; }
  .brand-text { font-family: var(--font-display); font-weight: 700; font-size: 1.2rem; color: #fff; letter-spacing: -0.02em; }
  .footer-brand p { color: #B7A488; max-width: 320px; font-size: .95rem; line-height: 1.6; }

  .socials { display: flex; gap: 18px; margin-top: 22px; }
  .socials a {
    font-size: .88rem; font-weight: 500; color: #B7A488;
    transition: color .2s ease;
  }
  .socials a:hover { color: var(--gold); }

  .footer-col h4 {
    font-family: var(--font-display); font-size: .8rem; letter-spacing: .12em; text-transform: uppercase;
    margin-bottom: 18px; color: #9A8468;
  }
  .footer-col a { display: block; color: #E4D6C2; padding: 6px 0; font-size: .95rem; transition: color .18s ease; }
  .footer-col a:hover { color: #fff; }
  .footer-col .muted { color: #B7A488; margin-bottom: 14px; font-size: .95rem; line-height: 1.6; }

  .footer-bottom {
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 10px;
    margin-top: 54px; padding-top: 26px;
    border-top: 1px solid rgba(255,255,255,.08);
    color: #9A8468; font-size: .86rem;
  }

  @media (max-width: 860px) {
    .footer-inner { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .footer-inner { grid-template-columns: 1fr; gap: 30px; }
  }
</style>
