---
// Demo gate shown for pages that aren't part of the free demo build.
const {
  title = "You're one step away from a complete website",
  text = "This is a free demo we built for your business. The full website includes this page, plus Contact, About Us, and more — all customised and ready to launch.",
} = Astro.props;

// WhatsApp number is used in the link only — never displayed.
const WHATSAPP = "60125890419";
const EMAIL = "kodestudio7@protonmail.com";
const waLink = `https://wa.me/${WHATSAPP}?text=${encodeURIComponent(
  "Hi Kode Studio, I'd like to unlock the full website."
)}`;
---

<section class="locked">
  <div class="locked-inner" data-reveal>
    <div class="lock-badge">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <rect x="5" y="11" width="14" height="9" rx="2" />
        <path d="M8 11V8a4 4 0 0 1 8 0v3" />
        <circle cx="12" cy="15.5" r="1.2" fill="currentColor" stroke="none" />
      </svg>
    </div>

    <h1>{title}</h1>
    <p class="locked-text">{text}</p>

    <div class="locked-actions">
      <a class="lk-wa" href={waLink} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.15-1.7-.84-2-.94-.26-.1-.45-.15-.64.15-.19.29-.74.94-.9 1.13-.17.19-.33.21-.62.07-.3-.15-1.25-.46-2.38-1.47-.88-.78-1.47-1.75-1.64-2.04-.17-.29-.02-.45.13-.6.13-.13.3-.34.44-.51.15-.17.2-.29.3-.48.1-.19.05-.36-.02-.51-.08-.15-.64-1.55-.88-2.12-.23-.55-.47-.48-.64-.49l-.55-.01c-.19 0-.5.07-.76.36-.26.29-1 .98-1 2.38s1.02 2.76 1.17 2.95c.15.19 2.02 3.08 4.9 4.32.68.29 1.22.47 1.64.6.69.22 1.31.19 1.81.11.55-.08 1.7-.69 1.94-1.36.24-.67.24-1.24.17-1.36-.07-.12-.26-.19-.55-.34zM12 2a10 10 0 0 0-8.6 15.06L2 22l5.06-1.33A10 10 0 1 0 12 2z"/></svg>
        WhatsApp us now
      </a>
      <a class="lk-mail" href={`mailto:${EMAIL}`}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
        {EMAIL}
      </a>
    </div>

    <p class="locked-credit">Demo by Kode Studio · kodestudio.my</p>
  </div>
</section>

<style>
  .locked {
    display: grid; place-items: center;
    min-height: calc(100vh - 120px);
    padding: 150px 24px 110px;
    text-align: center;
  }
  .locked-inner { max-width: 620px; }
  .lock-badge {
    width: 92px; height: 92px; margin: 0 auto 36px;
    border-radius: 50%; display: grid; place-items: center;
    background: #fff; border: 1px solid var(--line); box-shadow: var(--shadow-sm);
    color: var(--ink);
  }
  .lock-badge svg { width: 38px; height: 38px; }
  .locked h1 {
    font-size: clamp(2rem, 4.6vw, 3rem); letter-spacing: -0.035em; line-height: 1.1;
  }
  .locked-text {
    font-size: 1.12rem; color: var(--ink-soft); line-height: 1.7;
    max-width: 520px; margin: 22px auto 40px;
  }
  .locked-actions { display: flex; flex-direction: column; gap: 14px; max-width: 380px; margin: 0 auto; }
  .lk-wa, .lk-mail {
    display: inline-flex; align-items: center; justify-content: center; gap: 12px;
    font-family: var(--font-display); font-weight: 700; font-size: 1.05rem;
    padding: 17px 26px; border-radius: 14px; transition: transform .2s ease, box-shadow .25s ease, background .2s ease;
  }
  .lk-wa { background: #25D366; color: #fff; box-shadow: 0 10px 24px rgba(37,211,102,.28); }
  .lk-wa:hover { transform: translateY(-2px); box-shadow: 0 14px 30px rgba(37,211,102,.36); background: #1ebe5b; }
  .lk-wa svg { width: 24px; height: 24px; }
  .lk-mail { background: #fff; color: var(--ink); border: 1px solid var(--line-strong); }
  .lk-mail:hover { transform: translateY(-2px); border-color: var(--ink); box-shadow: var(--shadow-sm); }
  .lk-mail svg { width: 22px; height: 22px; }
  .locked-credit { margin-top: 44px; font-size: .9rem; font-weight: 600; color: var(--ink-soft); }
</style>
