---
// Smooth "oval" section divider (single-arc curve). side="top" curves the
// section's top edge, side="bottom" the bottom. Fill matches the paper colour.
const { side = "top" } = Astro.props;
---
<div class={`wave wave-${side === "top" ? "t" : "b"}`} aria-hidden="true">
  <svg viewBox="0 0 1440 90" preserveAspectRatio="none">
    <path d="M0,0 H1440 V50 Q720,-22 0,50 Z" fill="var(--paper)" />
  </svg>
</div>

<style>
  .wave { position: absolute; left: 0; width: 100%; line-height: 0; z-index: 2; pointer-events: none; }
  .wave svg { display: block; width: 100%; height: clamp(48px, 6.5vw, 90px); }
  .wave-t { top: -1px; }
  .wave-b { bottom: -1px; transform: scaleY(-1); }
</style>
