---
const { eyebrow, title, subtitle } = Astro.props;
---

<section class="page-header">
  <div class="container" data-hero-stagger>
    {eyebrow && <span class="eyebrow eyebrow-light">{eyebrow}</span>}
    <h1 data-split>{title}</h1>
    <span class="ph-rule" aria-hidden="true"></span>
    {subtitle && <p class="ph-sub">{subtitle}</p>}
  </div>
  <div class="ph-curve" aria-hidden="true">
    <svg viewBox="0 0 1440 110" preserveAspectRatio="none"><path d="M0,110 L0,55 Q720,-15 1440,55 L1440,110 Z" fill="var(--paper)"/></svg>
  </div>
</section>

<style>
  .page-header {
    position: relative;
    background: var(--red-deep);
    background-image: radial-gradient(120% 140% at 70% 0%, var(--red) 0%, var(--red-deep) 70%);
    padding: 160px 0 132px;
    text-align: center;
    overflow: hidden;
  }
  .ph-rule { display: block; width: 64px; height: 3px; border-radius: 2px; background: var(--gold); margin: 24px auto 0; }
  .page-header .eyebrow-light, .page-header .eyebrow-light::before { color: var(--gold); }
  .page-header .eyebrow-light::before { background: var(--gold); }
  .page-header .eyebrow { justify-content: center; margin-bottom: 18px; }
  .page-header h1 {
    color: #fff;
    font-size: clamp(2.6rem, 6vw, 4.4rem);
    letter-spacing: -0.04em;
    text-shadow: 0 4px 40px rgba(0,0,0,.25);
  }
  .ph-sub { color: rgba(255,255,255,.86); font-size: 1.12rem; line-height: 1.6; max-width: 640px; margin: 18px auto 0; }
  .ph-curve { position: absolute; left: 0; right: 0; bottom: -1px; line-height: 0; pointer-events: none; }
  .ph-curve svg { width: 100%; height: clamp(48px, 6vw, 90px); display: block; }
</style>
